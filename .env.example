# Firebase Configuration Keys
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT.firebaseapp.com"
VITE_FIREBASE_DATABASE_URL="https://YOUR_PROJECT-default-rtdb.firebasedatabase.app"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_APP_ID"

# reCAPTCHA Configuration (Firebase App Check)
VITE_RECAPTCHA_SITE_KEY="YOUR_RECAPTCHA_V3_SITE_KEY"

# Gemini AI API Key (for the AI Search Bot in sidebar)
# Get a free key from: https://aistudio.google.com/app/apikey
# Users can also paste their key directly in the chatbot UI settings panel
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
